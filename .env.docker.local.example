# Local Docker development environment overrides.
#
# Copy this file to `.env.docker.local` and fill in real values. The copy is
# git-ignored (see `.env*.local` in .gitignore) so credentials never get
# committed. These keys point the test/dev tooling at the docker-compose
# Postgres instance (see docker-compose.yml for the matching defaults).

export HUBUUM_TEST_DB_HOST=127.0.0.1
export HUBUUM_TEST_DB_PORT=9998
export HUBUUM_TEST_DB_USER=your_db_user
export HUBUUM_TEST_DB_PASSWORD=your_db_password

export HUBUUM_DATABASE_URL=postgres://your_db_user:your_db_password@${HUBUUM_TEST_DB_HOST}:${HUBUUM_TEST_DB_PORT}/hubuum
export DATABASE_URL=postgres://your_db_user:your_db_password@${HUBUUM_TEST_DB_HOST}:${HUBUUM_TEST_DB_PORT}/hubuum
